Options -Indexes

<IfModule mod_deflate.c>
  SetOutputFilter DEFLATE

  AddOutputFilterByType DEFLATE application/javascript
  AddOutputFilterByType DEFLATE application/wasm
  AddOutputFilterByType DEFLATE application/octet-stream
  AddOutputFilterByType DEFLATE text/html
  AddOutputFilterByType DEFLATE text/plain
  AddOutputFilterByType DEFLATE text/css

  AddType application/wasm .wasm
  AddType application/javascript .js
  AddType application/octet-stream .data
</IfModule>

<IfModule mod_headers.c>
  Header set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-eval'; style-src 'self' 'unsafe-inline';"
</IfModule>

<FilesMatch "^(index\.html|desktop\.html|mobile\.html|bootstrap\.js|desktopApp\.js|mobileApp\.js)$">
  Header set Cache-Control "no-cache, must-revalidate"
</FilesMatch>

<FilesMatch "^Build(Desktop|Mobile)/.*\.(data|wasm|js)$">
  Header set Cache-Control "public, max-age=31536000, immutable"
</FilesMatch>

<Files "favicon.ico">
  Header set Cache-Control "public, max-age=86400"
</Files>
